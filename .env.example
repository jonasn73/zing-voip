# Copy to .env.local and fill in values.
# Never commit .env.local (it's in .gitignore).

# Database - use Neon (free): https://neon.tech → New Project → Connection string → URI
# Paste the full URI here (it looks like this, with your real host/password):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
#
# If you see "password authentication failed for user postgres", you're still using
# the old local URL - replace DATABASE_URL in .env.local with your Neon URI above.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zing

# Optional: in-app Help & Support / Security & Privacy (Settings links)
# When set, Security & Privacy and Help & Support open these URLs in a new tab.
# When not set, they open the in-app /privacy and /support pages.
# NEXT_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.com/privacy
# NEXT_PUBLIC_SUPPORT_URL=https://your-domain.com/help
# NEXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.com  (used on /support page when NEXT_PUBLIC_SUPPORT_URL is not set)
# Mobile: set EXPO_PUBLIC_PRIVACY_POLICY_URL and EXPO_PUBLIC_SUPPORT_URL in mobile/.env or EAS env

# Twilio (optional for call routing)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session signing (use: openssl rand -base64 32)
# SESSION_SECRET=

# AI receptionist (server-side — your customers never set these)
# VAPI_API_KEY=                    # Vapi private key (live assistant)
# ELEVENLABS_API_KEY=              # Platform key: voice preview + voice catalog in Settings
# ZING_AI_LLM_MODEL=gpt-4o-mini   # Optional; default in app is gpt-4o for quality

# Optional: dev-only login when database is not connected (development only)
# Use these credentials on the login form to get in without a DB.
# DEV_LOGIN_EMAIL=you@example.com
# DEV_LOGIN_PASSWORD=yourpassword
